# Скопируйте в .env и подправьте значения:
#   cp .env.example .env
#
# Docker Compose подхватывает .env из каталога с docker-compose.yml
# для подстановки ${VAR} в этом файле compose.

# Публичный URL сайта (HTTPS, без завершающего слэша).
# Совпадает с тем, как пользователи открывают приложение в браузере.
PUBLIC_BASE_URL=https://localhost

# MySQL (имя БД и пользователь должны совпадать с тем, что ожидает backend)
MYSQL_DATABASE=widget_app
MYSQL_USER=widget
MYSQL_PASSWORD=widget_secret
MYSQL_ROOT_PASSWORD=root_secret

# phpMyAdmin (docker compose): порт на хосте и полный URL интерфейса (редиректы после логина)
PHPMYADMIN_PORT=8081
# PHPMYADMIN_ABSOLUTE_URI=http://localhost:8081/

# Подпись JWT для API (в продакшене — длинная случайная строка)
JWT_SECRET=change_me_in_production_use_long_random_string
